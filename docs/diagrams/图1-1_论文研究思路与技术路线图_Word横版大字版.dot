digraph G {
  graph [
    rankdir=TB,
    bgcolor="white",
    dpi=240,
    nodesep=0.7,
    ranksep=0.7,
    splines=ortho,
    label="图1-1 论文研究思路与技术路线图",
    labelloc="t",
    fontsize=18,
    fontname="Microsoft YaHei",
    pad=0.2
  ];

  node [
    shape=box,
    style="rounded",
    color="black",
    fontname="Microsoft YaHei",
    fontsize=15,
    margin="0.22,0.15",
    width=3.0,
    height=0.9
  ];

  edge [
    color="black",
    arrowsize=0.8,
    penwidth=1.1
  ];

  bg [label="企业背景与现实约束\n南派食品存在批次追溯、权限边界\n流程脱节与冷库弱网等问题"];
  req [label="需求分析\n组织与主数据、物料与仓储\n流程协同、语义解释、移动场景"];
  arch [label="系统总体设计\n数据库中心架构\n微前端拆分核心模块"];
  key [label="关键技术路线\nPostgreSQL + PostgREST\nVue 3 + qiankun\nBPMN + 轻量语义增强"];
  impl [label="系统实现\n人事、物料、应用中心、移动端\n闪念应用、Agent Runtime、冷库模式"];
  verify [label="测试与验证\n登录鉴权、页面访问、库存链路\n流程读取与受控工具验证"];
  thesis [label="论文形成\n绪论→需求分析→总体设计→数据库设计\n详细设计→系统实现→测试与总结"];

  { rank=same; bg; req; }
  { rank=same; arch; key; }
  { rank=same; impl; verify; }

  bg -> req [style=invis];
  arch -> key [style=invis];
  impl -> verify [style=invis];

  bg -> arch;
  req -> key;
  arch -> impl;
  key -> verify;
  impl -> thesis;
  verify -> thesis;
}
