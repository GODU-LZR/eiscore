@startuml
left to right direction
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Microsoft YaHei
skinparam packageStyle rectangle
title 图3-3（b）追溯与经营管理用例图

actor 仓管员
actor 销售文员
actor 管理层

rectangle EISCore {
  usecase "订单/批次正向追溯" as UC1
  usecase "订单/批次反向追溯" as UC2
  usecase "物流信息登记" as UC3
  usecase "经营统计与驾驶舱查看" as UC4
}

仓管员 -- UC1
仓管员 -- UC2
销售文员 -- UC3
管理层 -- UC4

UC1 .> UC3 : <<include>>
UC2 .> UC3 : <<include>>
@enduml
