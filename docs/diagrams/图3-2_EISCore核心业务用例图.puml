@startuml
left to right direction
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Microsoft YaHei
skinparam packageStyle rectangle
title 图3-2 EISCore核心业务用例图

actor 销售文员
actor "PMC计划员" as PMC
actor 采购员
actor 仓管员
actor "生产主管" as Prod
actor 系统管理员

rectangle EISCore {
  usecase "销售合同录入" as UC1
  usecase "销售订单下推" as UC2
  usecase "订单执行状态查询" as UC3

  usecase "生产计划下达" as UC4
  usecase "物料需求分析" as UC5
  usecase "采购需求生成" as UC6

  usecase "采购订单维护" as UC7
  usecase "到货登记" as UC8
  usecase "采购入库" as UC9

  usecase "生产领料申请" as UC10
  usecase "生产补料申请" as UC11
  usecase "生产入库登记" as UC12

  usecase "销售出库办理" as UC13
  usecase "库存台账与批次查询" as UC14
  usecase "批次号规则维护" as UC15
}

销售文员 -- UC1
销售文员 -- UC2
销售文员 -- UC3
销售文员 -- UC13

PMC -- UC3
PMC -- UC4
PMC -- UC5
PMC -- UC6
PMC -- UC14

采购员 -- UC7
采购员 -- UC8
采购员 -- UC9

仓管员 -- UC8
仓管员 -- UC9
仓管员 -- UC10
仓管员 -- UC11
仓管员 -- UC12
仓管员 -- UC13
仓管员 -- UC14

Prod -- UC10
Prod -- UC11
Prod -- UC12

系统管理员 -- UC15

UC2 .> UC1 : <<include>>
UC4 .> UC5 : <<include>>
UC7 .> UC6 : <<include>>
UC9 .> UC8 : <<include>>
UC11 .> UC10 : <<extend>>
UC13 .> UC3 : <<include>>
UC9 .> UC14 : <<include>>
UC10 .> UC14 : <<include>>
UC13 .> UC14 : <<include>>
@enduml
